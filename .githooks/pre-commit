#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: Go formatting, vet, and lint
# Runs on staged .go files only for speed.

# Collect staged Go files (excluding deleted files and vendor)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.go' | grep -v '^vendor/' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  exit 0
fi

PASS=true

# --- gofmt (auto-fix) ---
UNFORMATTED=$(echo "$STAGED_GO_FILES" | xargs gofmt -l 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
  echo "$UNFORMATTED" | xargs gofmt -w
  echo "$UNFORMATTED" | xargs git add
  echo "✔ gofmt: auto-formatted and re-staged:"
  echo "$UNFORMATTED"
fi

# --- go vet ---
if ! go vet -mod=vendor ./... 2>&1; then
  echo "❌ go vet: issues found"
  PASS=false
fi

# --- golangci-lint ---
if command -v golangci-lint &>/dev/null; then
  if ! golangci-lint run 2>&1; then
    echo "❌ golangci-lint: issues found"
    PASS=false
  fi
fi

if ! $PASS; then
  echo ""
  echo "Pre-commit checks failed. Fix the issues above and try again."
  exit 1
fi

echo "✅ Pre-commit checks passed"
